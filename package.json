{
  "name": "action-setup-authentik",
  "description": "Sets up an authentik test environment",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "npx vitest run --coverage --reporter=default --reporter=junit --outputFile=./coverage/junit.xml",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "package": "npx rimraf ./dist && npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "test": "npx vitest run --coverage",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "dependencies": {
    "@actions/cache": "^6.1.0",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vercel/ncc": "^0.44.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/eslint-plugin": "^1.6.23",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-jsonc": "^3.2.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prettier-eslint": "^17.1.1",
    "rollup": "^4.62.2",
    "typescript": "^6.0.3"
  }
}
